# Copia este archivo como .env para desarrollo local
# En Render, configura estas variables en Environment > Environment Variables

MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?appName=NombreApp
PORT=5000

# URL del frontend en Netlify (sin slash al final)
# Ejemplo: https://tu-proyecto.netlify.app
FRONTEND_URL=https://TU-PROYECTO.netlify.app

GOOGLE_SHEETS_HOOK=https://script.google.com/macros/s/TU_HOOK/exec

GMAIL_USER=tu@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
